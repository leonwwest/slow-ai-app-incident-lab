# Copy to .env and adjust. All values are optional - defaults are safe for
# local use. See app/config.py for how these are consumed.

# Local SQLite database location (relative to repo root).
INCIDENT_LAB_DB_PATH=data/incident_lab.db

# Deployment metadata used in logs and the /health response.
DEPLOYMENT_VERSION=v1.4.0
REGION=eu-central-1

# Simulated AI provider pricing in USD per 1K tokens.
PRICE_INPUT_PER_1K=0.010
PRICE_OUTPUT_PER_1K=0.030

# Simulated provider hostname referenced by the DNS/network runbook section.
AI_PROVIDER_HOST=api.simulated-ai-provider.com

# Simulated API key. Leave EMPTY to reproduce the example incident's 401
# failures on /chat and /chat/slow. Set to any non-empty value to "fix" IAM.
AI_API_KEY=
