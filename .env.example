# Copy to .env and adjust. All values are optional - defaults are safe for
# local use. See app/config.py for how these are consumed.

# --- Database backend -----------------------------------------------------
# "sqlite" (default, zero-setup) or "postgres" (Docker Compose / prod).
DB_BACKEND=sqlite
INCIDENT_LAB_DB_PATH=data/incident_lab.db
# Used only when DB_BACKEND=postgres:
DATABASE_URL=postgresql://incident:incident@localhost:5432/incident_lab

# --- Deployment metadata --------------------------------------------------
DEPLOYMENT_VERSION=v1.4.0
REGION=eu-central-1

# --- Simulated AI provider ------------------------------------------------
PRICE_INPUT_PER_1K=0.010
PRICE_OUTPUT_PER_1K=0.030
AI_PROVIDER_HOST=api.simulated-ai-provider.com
# Leave EMPTY to reproduce the example incident's 401 failures.
AI_API_KEY=

# --- Observability --------------------------------------------------------
ENABLE_METRICS=true
# Tracing requires opentelemetry packages + a collector (Jaeger/Tempo).
# Disabled by default for zero-setup local runs; enabled in docker-compose.
ENABLE_TRACING=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=slow-ai-app
